# Copy this file to .env and edit as needed.
# All values shown are the defaults — only uncomment lines you want to change.

# ── Proxy settings ──
# LISTEN_PORT=8318
# TARGET_PROTOCOL=https
# TARGET_HOST=agentrouter.org
# TARGET_PORT=443
# REQUEST_TIMEOUT_MS=120000

# ── Models ──
# Static fallback list (comma-separated). Used when AR_API_KEY is not set.
# MODELS_CSV=claude-opus-4-6,claude-opus-4-7,claude-opus-4-8,glm-5.2,gpt-5.5

# ── WAF cookie warmup ──
# WARMUP_INTERVAL_MS=180000

# ── Retry / circuit breaker ──
# MAX_RETRIES=2
# RETRY_DELAY_MS=1000

# ── Model auto-discovery (optional) ──
# Set your AgentRouter API key to enable dynamic model listing.
# AR_API_KEY=
# DISCOVERY_INTERVAL_MS=600000

# ── Timeouts ──
# Maximum time to wait for upstream to start responding (ms). Default 300000 (5 min).
# REQUEST_TIMEOUT_MS=300000
# Response timeout: wait this long for HTTP response headers. Default 30000 (30s).
# RESPONSE_TIMEOUT_MS=30000
# SSE idle timeout: if no streaming data arrives within this window, the stream
# is terminated. Default 600000 (10 min).
# SSE_IDLE_TIMEOUT_MS=600000
# SSE chunk timeout: if no data chunk arrives within this window during streaming,
# the stream is stalled. Before any real data arrives (keepalive-only mode),
# caps at 60000 (60s) regardless of this value. Default 30000 (30s).
# SSE_CHUNK_TIMEOUT_MS=30000
LOG_LEVEL=info

# ── Prompt injection (optional) ──
# System prompt injected into every request (bypass filtering, jailbreak, etc.)
# INJECT_SYSTEM_PROMPT=
